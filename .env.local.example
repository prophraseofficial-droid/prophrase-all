# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite
# Blocks models outside the server-side free-tier allowlist. Billing must also
# remain disabled on the Google project to guarantee zero Gemini API charges.
GEMINI_FREE_ONLY=true
PROPHRASE_PROMPT_V2_ENABLED=true
REWRITE_GEMINI_MAX_OUTPUT_TOKENS=1200
OUTCOME_GEMINI_MAX_OUTPUT_TOKENS=2800
GEMINI_REWRITE_THINKING_BUDGET=0
GEMINI_OUTCOME_THINKING_BUDGET=1024

# Users created on or after this timestamp receive Quick Styles onboarding.
QUICK_STYLES_ONBOARDING_CUTOFF=2026-07-12T00:00:00.000Z
NEXT_PUBLIC_PREFERENCES_ENABLED=true

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Legacy Razorpay plan IDs (recognition/migration only; never used for new checkout)
RAZORPAY_PLAN_MONTHLY_ID=
RAZORPAY_PLAN_YEARLY_ID=
# New sellable Razorpay plan IDs
RAZORPAY_PLUS_MONTHLY_PLAN_ID=
RAZORPAY_PLUS_ANNUAL_PLAN_ID=
RAZORPAY_PRO_MONTHLY_PLAN_ID=
RAZORPAY_PRO_ANNUAL_PLAN_ID=

# Credit and subscription configuration
FREE_DAILY_CREDITS=15
PLUS_MONTHLY_CREDITS=300
PRO_MONTHLY_CREDITS=1500
PLUS_MONTHLY_PRICE_PAISE=9900
PLUS_ANNUAL_PRICE_PAISE=89900
PRO_MONTHLY_PRICE_PAISE=24900
PRO_ANNUAL_PRICE_PAISE=199900
BILLING_CURRENCY=INR
BILLING_TAX_NOTE=Taxes may apply at checkout.
BILLING_GRACE_PERIOD_DAYS=3
DEFAULT_CREDIT_TIMEZONE=Asia/Kolkata

# Safe rollout defaults
CREDIT_BILLING_ENABLED=false
CREDIT_BILLING_SHADOW_MODE=true
PRICING_PAGE_ENABLED=true
PAID_CHECKOUT_ENABLED=false
PLAN_FEATURE_GATING_ENABLED=false
CREDIT_USAGE_HISTORY_ENABLED=false
FOUNDER_OFFER_ENABLED=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_OUTCOME_ASSISTANT_ENABLED=false
OUTCOME_ASSISTANT_ENABLED=false
APP_ENV=development
